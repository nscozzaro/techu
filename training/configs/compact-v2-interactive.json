{
  "description": "Fast-iteration CNN compact value net for interactive dashboard use.",
  "datasetGames": 400,
  "datasetMix": {
    "teacherSelf": 0.35,
    "vsFull": 0.25,
    "vsStatic": 0.25,
    "vsRandom": 0.15
  },
  "teacherSearch": {
    "depth": 4,
    "rootMoveLimit": 9,
    "nodeMoveLimit": 5,
    "discardLimit": 2,
    "tacticalWidth": 4,
    "staticBlend": 0.01,
    "timeMs": 42,
    "nodeBudget": 3600
  },
  "minTeacherDepth": 2,
  "targetScale": 480,
  "validationFraction": 0.1,
  "epochs": 15,
  "batchSize": 64,
  "learningRate": 0.0012,
  "lrSchedule": "cosine",
  "lrMin": 0.00008,
  "weightDecay": 0.0001,
  "gradClip": 1.0,
  "loss": "huber",
  "huberDelta": 0.75,
  "evalEvery": 3,
  "evalPairsRandom": 8,
  "evalPairsStatic": 8,
  "evalPairsFull": 8,
  "evalPairsFrozen": 8,
  "stopPairsStatic": 8,
  "stopPairsFull": 8,
  "stopTargets": {
    "vsStatic": 1.0,
    "vsFull": 0.6
  },
  "inference": {
    "leafScale": 420,
    "leafBlend": 0.85
  },
  "checkpointDir": "training/checkpoints",
  "deployPath": "flood-compact-model.json"
}
